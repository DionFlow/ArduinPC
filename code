  pinMode(buttonY, INPUT_PULLUP);
  pinMode(buttonZ, INPUT_PULLUP);

  screen.begin();
  screen.background(0, 0, 0);
  screen.setTextSize(1);
  screen.stroke(255, 255, 255);
  screen.setRotation(2);
  
  showMainScreen();
}

void loop() {
  if (currentScreen == 0) {  // -Main screen
    if (digitalRead(buttonX) == LOW) {
      currentScreen = 1;  // programs
      showProgramsScreen();
      delay(200);
    }
    else if (digitalRead(buttonY) == LOW) {
      currentScreen = 5;  // folders
      folderLevel = 0;
      folderSelection = 0;
      showFoldersScreen();
      delay(200);
    }
    else if (digitalRead(buttonZ) == LOW) {  // cyberspace
      currentScreen = 7;
      showCyberspaceScreen();
      delay(200);
    }
  }
  
  else if (currentScreen == 1) {  // -Programs
    if (digitalRead(buttonX) == LOW) {
      currentScreen = 2;  // games
      showGamesScreen();
      delay(200);
    }
    else if (digitalRead(buttonY) == LOW) {
      currentScreen = 3;  // apps
      showAppsScreen();
      delay(200);
    }
    else if (digitalRead(buttonZ) == LOW) {
      currentScreen = 0;  // main
      showMainScreen();
      delay(200);
    }
  }
  
  else if (currentScreen == 2) {  // games
    if (digitalRead(buttonX) == LOW) {
      currentScreen = 4;  // detricomicon
      showDetricomiconScreen();
      gameActive = true;
      gameOver = false;
      playerPosition = 1;
      enemyX = random(0, 3);
      enemyY = 20;
      delay(200);
    }
    else if (digitalRead(buttonZ) == LOW) {
      currentScreen = 1;  // programs
      showProgramsScreen();
      delay(200);
    }
  }
  
  else if (currentScreen == 3) {  // apps
    if (digitalRead(buttonX) == LOW) {
      currentScreen = 6;  // calculator
      showCalculatorScreen();
      delay(200);
    }
    else if (digitalRead(buttonY) == LOW) {
      currentScreen = 8;  // maps
      showMapsScreen();
      delay(200);
    }
    else if (digitalRead(buttonZ) == LOW) {
      currentScreen = 1;  // programs
      showProgramsScreen();
      delay(200);
    }
  }
  
  else if (currentScreen == 4) {  // detricomicon
    gameLoop();
  }
  
  else if (currentScreen == 5) {  // folders
    foldersLoop();
  }
  
  else if (currentScreen == 6) {  // Calculator
    calculatorLoop();
  }
  
  else if (currentScreen == 7) {  // Cyberspace
    cyberspaceLoop();
  }
  
  else if (currentScreen == 8) {  // Maps
    mapsLoop();
  }

  else if (currentScreen == 9) {  //Test0
    testLoop();
  }
}

void gameLoop() {
  // Player
  if (digitalRead(buttonX) == LOW) {
    playerPosition = 0;
    updateGameDisplay();
    delay(150);
  }
  else if (digitalRead(buttonY) == LOW) {
    playerPosition = 1;
    updateGameDisplay();
    delay(150);
  }
  else if (digitalRead(buttonZ) == LOW) {
    if (gameOver) {
      currentScreen = 2;  // games
      showGamesScreen();
    } else {
      playerPosition = 2;
      updateGameDisplay();
    }
    delay(150);
  }
  
  // Enemy blue dot
  if (gameActive && !gameOver && millis() - lastEnemyMove > enemyMoveDelay) {
    enemyY += enemyStep;
    
    if (enemyY >= 115) {
      if (enemyX == playerPosition) {
        gameOver = true;
        updateGameDisplay();
      } else {
        enemyY = 20;
        enemyX = random(0, 3);
        updateGameDisplay();
      }
    }
    
    updateGameDisplay();
    lastEnemyMove = millis();
  }
}

