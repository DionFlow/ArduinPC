void updateGameDisplay() {
  screen.stroke(0, 0, 0);
  screen.fill(0, 0, 0);
  screen.rect(0, 0, 160, 125);
  
  // Lines
  screen.stroke(255, 255, 255);
  screen.line(40, 0, 40, 145);
  screen.line(85, 0, 85, 145);
  
  // Positions
  screen.stroke(255, 255, 255);
  screen.fill(0, 0, 0);
  
  screen.rect(5, 130, 30, 15);
  screen.rect(45, 130, 35, 15);
  screen.rect(90, 130, 30, 15);
  
  // Player
  switch(playerPosition) {
    case 0:
      screen.fill(0, 255, 0);
      screen.rect(5, 130, 30, 15);
      break;
    case 1:
      screen.fill(0, 255, 0);
      screen.rect(45, 130, 35, 15);
      break;
    case 2:
      screen.fill(0, 255, 0);
      screen.rect(90, 130, 30, 15);
      break;
  }
  
  // Enemy
  if (!gameOver) {
    int enemyScreenX;
    switch(enemyX) {
      case 0: enemyScreenX = 20; break;
      case 1: enemyScreenX = 62; break;
      case 2: enemyScreenX = 105; break;
    }
    
    screen.stroke(255, 0, 0);
    screen.fill(255, 0, 0);
    screen.circle(enemyScreenX, enemyY, 8);
  }
  
  screen.stroke(255, 255, 255);
  screen.setTextSize(1);
  screen.text("x - 1: y - 2: z - 3", 7, 150);
  
  // Game Over
  if (gameOver) {
    screen.stroke(0, 0, 255);
    screen.setTextSize(2);
    screen.text("GAME", 40, 50);
    screen.text("OVER", 45, 70);
    screen.setTextSize(1);
    screen.stroke(255, 255, 255);
    screen.text("z - back", 45, 100);
  }
}

