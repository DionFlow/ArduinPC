// Calculator
void drawCalculatorScreen() {
  screen.background(0, 0, 0);
  
  screen.text("grams/apps/calculator", 0, 0);
  
  screen.fill(0, 0, 0);
  screen.stroke(255, 255, 255);
  screen.rect(5, 15, 110, 25);
  
  screen.setTextSize(1);
  screen.stroke(0, 255, 255);
  
  if (calcError) {
    screen.text("Error 01", 10, 22);
  } else if (calcDisplay.length() > 0) {
    screen.text(calcDisplay.c_str(), 10, 22);
  } else {
    screen.text("0", 10, 22);
  }
  
  // Buttons
  for (int row = 0; row < 3; row++) {
    for (int col = 0; col < 5; col++) {
      int x = 5 + (col * 18);  
      int y = 50 + (row * 18);
      
      // is Choosen 
      int buttonIndex = row * 5 + col;
      if (buttonIndex == calcCursorPos) {
        screen.stroke(0, 255, 0);
        screen.fill(0, 255, 0);
      } else {
        screen.stroke(255, 255, 255);
        screen.noFill();
      }
      
      // Draw Button
      screen.rect(x, y, 15, 14);
      screen.stroke(255, 255, 255);
      screen.text(calcButtons[row][col], x + 3, y + 3);
    }
  }
  
  screen.stroke(150, 150, 150);
  screen.setTextSize(1);
  screen.text("X-move Y-select Z-back", 0, 120);
}

// Cyberspace Screen
void showCyberspaceScreen() {
  currentScreen = 7;
  cyberspaceInput = ""; 
  cyberspaceResult = -1;
  drawCyberspaceScreen();
}

void drawCyberspaceScreen() {
  screen.background(0, 0, 0);
  
  // Stars
  screen.stroke(0, 255, 0);
  for (int i = 0; i < 50; i++) {
    int x = random(0, 128);
    int y = random(0, 140);
    screen.point(x, y);
  }
  
  screen.stroke(0, 255, 0);
  screen.setTextSize(1);
  screen.text("> cyberspace", 25, 10);
  
  screen.stroke(255, 255, 255);
  screen.text("$:/", 5, 40);
  
  if (cyberspaceInput.length() > 0) {
    screen.stroke(255, 255, 255);
    screen.text(cyberspaceInput.c_str(), 25, 40);
  }
  
  if (cyberspaceResult != -1) {
    screen.stroke(0, 255, 0);
    screen.text("Leaving cyberspace", 10, 70);
    
    char loadingMsg[30];
    sprintf(loadingMsg, "Loading screen %d...", cyberspaceResult);
    screen.text(loadingMsg, 10, 85);
  }

  screen.stroke(150, 150, 150);
  screen.text("x-add * y-enter z-leave", 0, 145);
}

