void calculatorLoop() {
  // Cursor move
  if (digitalRead(buttonX) == LOW) {
    calcCursorPos++;
    if (calcCursorPos >= 15) {  
      calcCursorPos = 0;
    }
    drawCalculatorScreen();
    delay(200);
  }
  
  else if (digitalRead(buttonY) == LOW) {
    int row = calcCursorPos / 5;
    int col = calcCursorPos % 5;
    String button = calcButtons[row][col];
    
    //funny buttons
    if (button == "=") {
      // result
      if (calcDisplay.length() > 0) {
        if (calcDisplay.indexOf("+") > 0) {
          int pos = calcDisplay.indexOf("+");
          float a = calcDisplay.substring(0, pos).toFloat();
          float b = calcDisplay.substring(pos + 1).toFloat();
          calcResult = a + b;
          calcDisplay = String(calcResult);
        }
        else if (calcDisplay.indexOf("-") > 0) {
          int pos = calcDisplay.indexOf("-");
          float a = calcDisplay.substring(0, pos).toFloat();
          float b = calcDisplay.substring(pos + 1).toFloat();
          calcResult = a - b;
          calcDisplay = String(calcResult);
        }
        else if (calcDisplay.indexOf("x") > 0) {
          int pos = calcDisplay.indexOf("x");
          float a = calcDisplay.substring(0, pos).toFloat();
          float b = calcDisplay.substring(pos + 1).toFloat();
          calcResult = a * b;
          calcDisplay = String(calcResult);
        }
        else if (calcDisplay.indexOf(":") > 0) {
          int pos = calcDisplay.indexOf(":");
          float a = calcDisplay.substring(0, pos).toFloat();
          float b = calcDisplay.substring(pos + 1).toFloat();
          if (b != 0) {
            calcResult = a / b;
            calcDisplay = String(calcResult);
          } else {
            calcError = true;
          }
        }
      }
    }
    else if (button == "+" || button == "-" || button == "x" || button == ":") {
      if (calcDisplay.length() > 0 && !calcError) {
        calcDisplay += button;
      }
    }
    else {
      if (!calcError) {
        calcDisplay += button;
      }
    }
    
    drawCalculatorScreen(); 
    delay(200);
  }
  
  else if (digitalRead(buttonZ) == LOW) {
    currentScreen = 3;  // apps
    showAppsScreen();
    delay(200);
  }
}

void cyberspaceLoop() {
  // starfall
  if (digitalRead(buttonX) == LOW) {
    if (cyberspaceResult == -1) { 
      cyberspaceInput += "*";
      drawCyberspaceScreen();
    }
    delay(200);
  }
  
  // Check
  else if (digitalRead(buttonY) == LOW) {
    if (cyberspaceResult == -1) { 
      if (cyberspaceInput == "*") {
        cyberspaceResult = 1;  // programs
      }
      else if (cyberspaceInput == "**") {
        cyberspaceResult = 2;  // games
      }
      else if (cyberspaceInput == "***") {
        cyberspaceResult = 3;  // apps
      }
      else if (cyberspaceInput == "****") {
        cyberspaceResult = 4;  // detricomicon
      }
      else if (cyberspaceInput == "*****") {
        cyberspaceResult = 5;  // folders
      }
      else if (cyberspaceInput == "******") {
        cyberspaceResult = 6;  // calculator
      }
      else if (cyberspaceInput == "*******") {
        cyberspaceResult = 7;  // cyberspace
      }
      else if (cyberspaceInput == "********") {
        cyberspaceResult = 8;  // maps
      }
      else if (cyberspaceInput == "*********") {
        cyberspaceResult = 9;  // test0
      }
      else {
        // WRONG
        screen.stroke(0, 0, 255);
        screen.text("Error 02", 0, 70);
        screen.text("ARDUINPC://cyberspace", 0, 80);
        delay(1000);
        cyberspaceInput = ""; 
        drawCyberspaceScreen();
        delay(200);
        return;
      }
      
      drawCyberspaceScreen();
      delay(1000);  
      
      if (cyberspaceResult >= 1 && cyberspaceResult <= 9) {
        currentScreen = cyberspaceResult;
        
        switch(cyberspaceResult) {
          case 1: showProgramsScreen(); break;
          case 2: showGamesScreen(); break;
          case 3: showAppsScreen(); break;
          case 4: 
            showDetricomiconScreen();
            gameActive = true;
            gameOver = false;
            playerPosition = 1;
            enemyX = random(0, 3);
            enemyY = 20;
            break;
          case 5: showFoldersScreen(); break;
          case 6: showCalculatorScreen(); break;
          case 7: showCyberspaceScreen(); break; 
          case 8: showMapsScreen(); break;
          case 9: showTestScreen(); break;
        }
      }
    }
    delay(200);
  }
  
  else if (digitalRead(buttonZ) == LOW) {
    currentScreen = 0;  // Main
    showMainScreen();
    delay(200);
  }
}

